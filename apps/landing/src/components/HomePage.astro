<script>
  const syncMotionState = () => {
    const root = document.documentElement;
    const body = document.body;
    const motionDisabled =
      window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
      root.dataset.animations === "off" ||
      root.dataset.motion === "off" ||
      body.dataset.animations === "off" ||
      body.dataset.motion === "off" ||
      body.classList.contains("reduce-motion") ||
      body.classList.contains("motion-disabled");

    body.classList.toggle("motion-enabled", !motionDisabled);
  };

  syncMotionState();

  const motionObserver = new MutationObserver(() => syncMotionState());
  motionObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-animations", "data-motion", "class"],
  });
  motionObserver.observe(document.body, {
    attributes: true,
    attributeFilter: ["data-animations", "data-motion", "class"],
  });
  window.matchMedia("(prefers-reduced-motion: reduce)").addEventListener("change", syncMotionState);

  const toggleButtons =
    document.querySelectorAll<HTMLButtonElement>("[data-billing-toggle]");
  const prices =
    document.querySelectorAll<HTMLElement>("[data-monthly][data-yearly]");
  const ctaLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-href-base][data-plan]");

  function applyInterval(interval: "month" | "year") {
    for (const el of prices) {
      const value =
        interval === "year"
          ? el.getAttribute("data-yearly")
          : el.getAttribute("data-monthly");
      if (value) el.textContent = value;
    }

    for (const link of ctaLinks) {
      const base = link.getAttribute("data-href-base");
      const plan = link.getAttribute("data-plan");
      if (!base) continue;
      if (!plan) {
        link.setAttribute("href", base);
        continue;
      }
      link.setAttribute("href", `${base}?plan=${plan}&interval=${interval}`);
    }

    for (const button of toggleButtons) {
      const active = button.getAttribute("data-billing-toggle") === interval;
      if (active) {
        button.style.background = "var(--accent)";
        button.style.color = "var(--bg-primary)";
      } else {
        button.style.background = "transparent";
        button.style.color = "var(--text-secondary)";
      }
    }
  }

  for (const button of toggleButtons) {
    button.addEventListener("click", () => {
      const interval = button.getAttribute("data-billing-toggle");
      if (interval === "month" || interval === "year") {
        applyInterval(interval);
      }
    });
  }

  applyInterval("month");

  // Mobile menu
  const mobileNav = document.getElementById("mobile-nav");
  const openBtn = document.getElementById("mobile-menu-open");
  const closeBtn = document.getElementById("mobile-menu-close");

  openBtn?.addEventListener("click", () => {
    mobileNav?.classList.add("open");
    document.body.style.overflow = "hidden";
  });

  closeBtn?.addEventListener("click", () => {
    mobileNav?.classList.remove("open");
    document.body.style.overflow = "";
  });

  // Close mobile nav on link click
  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileNav.classList.remove("open");
      document.body.style.overflow = "";
    });
  });

  // PostHog CTA tracking
  document.querySelectorAll<HTMLAnchorElement>("a.solid-link, a.ghost-link").forEach((link) => {
    link.addEventListener("click", () => {
      const href = link.getAttribute("href") || "";
      const text = link.textContent?.trim() || "";
      if (typeof (window as any).posthog !== "undefined") {
        const section = link.closest("section")?.id || null;
        const inNav = !!link.closest("nav");
        (window as any).posthog.capture("landing_cta_clicked", {
          cta_text: text,
          cta_href: href,
          cta_location: section || (inNav ? "nav" : "page"),
        });
      }
    });
  });

  // Track pricing plan clicks specifically
  document.querySelectorAll<HTMLAnchorElement>("[data-plan]").forEach((link) => {
    link.addEventListener("click", () => {
      const plan = link.getAttribute("data-plan") || "";
      const href = link.getAttribute("href") || "";
      if (typeof (window as any).posthog !== "undefined") {
        (window as any).posthog.capture("landing_pricing_cta_clicked", {
          plan,
          href,
        });
      }
    });
  });

  // Scroll reveal animations
  const revealNodes = document.querySelectorAll<HTMLElement>(".reveal-on-scroll");
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        entry.target.classList.add("is-visible");
        observer.unobserve(entry.target);
      }
    },
    { threshold: 0.15, rootMargin: "0px 0px -8% 0px" },
  );
  revealNodes.forEach((node) => observer.observe(node));
</script>
