---
import Layout from "../layouts/Layout.astro";
import { useTranslations, localizedPath, type Locale } from "../i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const APP_URL = import.meta.env.PUBLIC_APP_URL || "http://localhost:5173";
const altLang = lang === "en" ? "fr" : "en";
const altPath = lang === "en" ? "/fr" : "/";

const howItWorks = [
  { step: "01", title: t("howItWorks.steps.define.title"), description: t("howItWorks.steps.define.desc") },
  { step: "02", title: t("howItWorks.steps.trigger.title"), description: t("howItWorks.steps.trigger.desc") },
  { step: "03", title: t("howItWorks.steps.deliver.title"), description: t("howItWorks.steps.deliver.desc") },
];

const coreFeatures = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6m-7-7h6m6 0h6"/><path d="M19.07 4.93l-4.24 4.24M9.17 14.83l-4.24 4.24M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24"/></svg>`,
    title: t("coreFeatures.modelAgnostic.title"),
    desc: t("coreFeatures.modelAgnostic.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>`,
    title: t("coreFeatures.variableInterpolation.title"),
    desc: t("coreFeatures.variableInterpolation.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 105.69-9.51L1 10"/></svg>`,
    title: t("coreFeatures.retriesConditions.title"),
    desc: t("coreFeatures.retriesConditions.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: t("coreFeatures.cronScheduling.title"),
    desc: t("coreFeatures.cronScheduling.desc"),
  },
];

const differentiators = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6m-7-7h6m6 0h6"/><path d="M19.07 4.93l-4.24 4.24M9.17 14.83l-4.24 4.24M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24"/></svg>`,
    title: t("differentiators.modelAgnostic.title"),
    desc: t("differentiators.modelAgnostic.desc"),
    proofLabel: t("differentiators.modelAgnostic.proof"),
    proofHref: "/docs/models-pricing",
    external: false,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: t("differentiators.privacy.title"),
    desc: t("differentiators.privacy.desc"),
    proofLabel: t("differentiators.privacy.proof"),
    proofHref: "/privacy",
    external: false,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
    title: t("differentiators.openSource.title"),
    desc: t("differentiators.openSource.desc"),
    proofLabel: t("differentiators.openSource.proof"),
    proofHref: "https://github.com/Ligerian-labs/automate",
    external: true,
  },
];

const secondaryFeatures = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: t("features.realTimeStreaming.title"),
    desc: t("features.realTimeStreaming.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: t("features.encryptedSecrets.title"),
    desc: t("features.encryptedSecrets.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: t("features.yamlImportExport.title"),
    desc: t("features.yamlImportExport.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    title: t("features.costTracking.title"),
    desc: t("features.costTracking.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
    title: t("features.apiWebhooks.title"),
    desc: t("features.apiWebhooks.desc"),
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: t("features.versionHistory.title"),
    desc: t("features.versionHistory.desc"),
  },
];

const pricing = [
  {
    name: "Starter",
    monthly: "19€",
    yearly: "205€",
    periodMonthly: "/month",
    periodYearly: "/year",
    caption: t("pricing.starter.caption"),
    items: t.array("pricing.starter.items"),
    cta: t("pricing.starter.cta"),
    featured: false,
    paid: true,
  },
  {
    name: "Pro",
    monthly: "49€",
    yearly: "529€",
    periodMonthly: "/month",
    periodYearly: "/year",
    caption: t("pricing.pro.caption"),
    items: t.array("pricing.pro.items"),
    cta: t("pricing.pro.cta"),
    featured: true,
    paid: true,
  },
  {
    name: "Enterprise",
    monthly: "Custom",
    yearly: "Custom",
    periodMonthly: "",
    periodYearly: "",
    caption: t("pricing.enterprise.caption"),
    items: t.array("pricing.enterprise.items"),
    cta: t("pricing.enterprise.cta"),
    featured: false,
    paid: false,
  },
];

const pipelineSteps = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: t("pipelineMockup.research"),
    model: "claude-sonnet-4",
    active: true,
    progress: 100,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: t("pipelineMockup.pickTopic"),
    model: "gpt-4o",
    active: true,
    progress: 70,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    title: t("pipelineMockup.writeDraft"),
    model: "claude-sonnet-4",
    active: false,
    progress: 0,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>`,
    title: t("pipelineMockup.qualityReview"),
    model: "claude-sonnet-4",
    active: false,
    progress: 0,
  },
];

const codeContent = `name: weekly-blog-generator
version: 1

variables:
  language: "fr"
  tone: "direct, pragmatic"

steps:
  - id: research
    model: claude-sonnet-4
    output_format: json
    retry:
      max_attempts: 2

  - id: write_draft
    model: claude-sonnet-4
    output_format: markdown`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "stepIQ",
    url: "https://stepiq.sh",
    sameAs: ["https://github.com/Ligerian-labs/automate"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "stepIQ",
    url: "https://stepiq.sh",
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "stepIQ",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Web",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
    },
    description:
      "Model-agnostic AI pipeline orchestration with usage-based credits and built-in cost tracking.",
  },
];
---

<Layout
  title={t("meta.title")}
  description={t("meta.description")}
  path={lp("/")}
  keywords={t("meta.keywords").split(", ")}
  structuredData={structuredData}
  lang={lang}
>
  <main class="landing">
    <header class="header">
      <div class="brand">
        <div class="logo-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><path d="M7 10v4a3 3 0 0 0 3 3h4"/><circle cx="17.5" cy="6.5" r="3.5"/></svg>
        </div>
        <span>stepIQ</span>
      </div>
      <nav class="nav-links">
        <a href="#why-stepiq">{t("nav.whyStepiq")}</a>
        <a href="#features">{t("nav.features")}</a>
        <a href="#pricing">{t("nav.pricing")}</a>
        <a href={lp("/docs")}>{t("nav.docs")}</a>
        <a href="#templates">{t("nav.templates")}</a>
      </nav>
      <div class="actions">
        <a href={altPath} class="ghost-link" style="padding:6px 10px;font-size:12px;letter-spacing:1px;font-weight:600;">{t("langSwitch")}</a>
        <a href={`${APP_URL}/login`} class="ghost-link">{t("nav.login")}</a>
        <a href={`${APP_URL}/register`} class="solid-link">{t("nav.getStarted")}</a>
      </div>
      <button type="button" class="mobile-menu-btn" aria-label="Open menu" id="mobile-menu-open">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </header>

    <div class="mobile-nav" id="mobile-nav">
      <div class="mobile-nav-header">
        <div class="brand">
          <div class="logo-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><path d="M7 10v4a3 3 0 0 0 3 3h4"/><circle cx="17.5" cy="6.5" r="3.5"/></svg>
          </div>
          <span>stepIQ</span>
        </div>
        <button type="button" class="mobile-nav-close" aria-label="Close menu" id="mobile-menu-close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <a href="#why-stepiq" class="mobile-nav-link">{t("nav.whyStepiq")}</a>
      <a href="#features" class="mobile-nav-link">{t("nav.features")}</a>
      <a href="#pricing" class="mobile-nav-link">{t("nav.pricing")}</a>
      <a href="/docs" class="mobile-nav-link">{t("nav.docs")}</a>
      <a href="#templates" class="mobile-nav-link">{t("nav.templates")}</a>
      <div class="mobile-nav-cta">
        <a href={`${APP_URL}/login`} class="outline-link">{t("nav.login")}</a>
        <a href={`${APP_URL}/register`} class="solid-link">{t("nav.getStarted")}</a>
      </div>
    </div>

    <section class="hero">
      <div class="beta-badge hero-reveal hero-reveal-1"><span class="dot"></span> {t("betaBadge")}</div>
      <div class="hero-text-wrap hero-reveal hero-reveal-2">
        <h1>{t("hero.h1_1")}<br />{t("hero.h1_2")}</h1>
        <p class="hero-sub">
          {t("hero.sub_1")}<br />
          {t("hero.sub_2")}
        </p>
      </div>
      <div class="hero-actions hero-reveal hero-reveal-3">
        <a href={`${APP_URL}/register`} class="solid-link">{t("hero.cta")} <span class="arrow-icon">→</span></a>
        <a href={lp("/docs")} class="outline-link">{t("hero.viewDocs")}</a>
      </div>

      <article class="pipeline-mockup hero-reveal hero-reveal-4" id="docs">
        <div class="mock-head">
          <strong class="mock-title">{t("pipelineMockup.weekly")}</strong>
          <span class="status"><span class="status-dot"></span> {t("pipelineMockup.running")}</span>
        </div>
        <div class="steps">
          {pipelineSteps.map((step, i) => (
            <>
              {i > 0 && <div class="arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>}
              <div class={`step ${step.active ? 'step-active' : 'step-pending'} ${i === 0 ? 'step-first' : ''} ${i === 1 ? 'step-second' : ''}`}>
                <span class="step-icon" set:html={step.icon} />
                <span class="step-title">{step.title}</span>
                <span class="step-model">{step.model}</span>
                <div class="step-bar">
                  <div class={`step-bar-fill ${step.active ? 'bar-accent' : 'bar-muted'}`} style={`width: ${step.active ? step.progress + '%' : '0%'}`}></div>
                </div>
              </div>
            </>
          ))}
        </div>
      </article>

      <div class="trust hero-reveal hero-reveal-5">
        <span class="trust-label">{t("trust.label")}</span>
        <span class="trust-sep"></span>
        <span>Anthropic</span>
        <span>OpenAI</span>
        <span>Meta Llama</span>
        <span>Mistral</span>
      </div>
    </section>

    <section class="section" id="why-stepiq">
      <div class="section-header reveal-on-scroll">
        <p class="kicker">{t("whyDifferent.kicker")}</p>
        <h2>{t("whyDifferent.h2")}</h2>
        <p class="section-sub">{t("whyDifferent.sub")}</p>
      </div>
      <div class="differentiators-grid">
        {differentiators.map((item) => (
          <article class="card differentiator-card reveal-on-scroll">
            <div class="feat-icon" set:html={item.icon} />
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <a
              href={item.proofHref}
              class="proof-link"
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
            >
              {item.proofLabel} <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header reveal-on-scroll">
        <p class="kicker">{t("howItWorks.kicker")}</p>
        <h2>{t("howItWorks.h2_1")}<br />{t("howItWorks.h2_2")}</h2>
        <p class="section-sub">{t("howItWorks.sub")}</p>
      </div>
      <div class="card-grid three">
        {howItWorks.map((item) => (
          <article class="card reveal-on-scroll">
            <div class="step-pill">{item.step}</div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="features">
      <div class="section-header reveal-on-scroll">
        <p class="kicker">{t("pipelineAsCode.kicker")}</p>
        <h2>{t("pipelineAsCode.h2")}</h2>
      </div>
      <div class="features-layout">
        <div class="code-card reveal-on-scroll">
          <div class="code-header">
            <div class="code-dots">
              <span class="code-dot red"></span>
              <span class="code-dot yellow"></span>
              <span class="code-dot green"></span>
            </div>
            <span class="code-filename">pipeline.yaml</span>
          </div>
          <pre class="code-body"><code set:html={codeContent
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/^(name|version|variables|steps):/gm, '<span class="hl-key">$&</span>')
            .replace(/(\s+)(retry:)/gm, '$1<span class="hl-key">$2</span>')
          } /></pre>
        </div>
        <div class="feat-cards">
          {coreFeatures.map((feat) => (
            <article class="card feat-card reveal-on-scroll">
              <div class="feat-icon" set:html={feat.icon} />
              <h3>{feat.title}</h3>
              <p>{feat.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="secondary-features">
      <div class="section-header reveal-on-scroll">
        <p class="kicker">{t("features.kicker")}</p>
        <h2>{t("features.h2")}</h2>
        <p class="section-sub">{t("features.sub")}</p>
      </div>
      <div class="card-grid three">
        {secondaryFeatures.map((feat) => (
          <article class="card feat-card reveal-on-scroll">
            <div class="feat-icon" set:html={feat.icon} />
            <h3>{feat.title}</h3>
            <p>{feat.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="pricing">
      <div class="section-header reveal-on-scroll">
        <p class="kicker">{t("pricing.kicker")}</p>
        <h2>{t("pricing.h2")}</h2>
        <p class="section-sub">{t("pricing.sub")}</p>
      </div>
      <div class="pricing-toggle" style="display:flex;justify-content:center;gap:8px;">
        <button type="button" data-billing-toggle="month" class="outline-link" style="padding:8px 14px;">{t("pricing.monthly")}</button>
        <button type="button" data-billing-toggle="year" class="outline-link" style="padding:8px 14px;">{t("pricing.yearlySave")}</button>
      </div>
      <div class="card-grid three">
        {pricing.map((plan) => (
          <article class={`card pricing-card reveal-on-scroll ${plan.featured ? "featured" : ""}`}>
            {plan.featured && <div class="popular-badge">{t("pricing.mostPopular")}</div>}
            <h3>{plan.name}</h3>
            <div class="price-row">
              <span
                class="price"
                data-monthly={plan.monthly}
                data-yearly={plan.yearly}
              >
                {plan.monthly}
              </span>
              {plan.periodMonthly && (
                <span
                  class="price-period"
                  data-monthly={plan.periodMonthly}
                  data-yearly={plan.periodYearly}
                >
                  {plan.periodMonthly}
                </span>
              )}
            </div>
            <p class="price-caption">{plan.caption}</p>
            <div class="price-sep"></div>
            <ul>
              {plan.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <a
              href={plan.name === "Enterprise" ? "/contact" : `${APP_URL}/register${plan.paid ? `?plan=${plan.name.toLowerCase()}&interval=month` : ""}`}
              data-href-base={plan.name === "Enterprise" ? "/contact" : `${APP_URL}/register`}
              data-plan={plan.paid ? plan.name.toLowerCase() : ""}
              class={plan.featured ? "solid-link" : "outline-link"}
            >
              {plan.cta}
            </a>
          </article>
        ))}
      </div>
    </section>

    <footer class="footer">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo-row">
            <div class="logo-icon">
