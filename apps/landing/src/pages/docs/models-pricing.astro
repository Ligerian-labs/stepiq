---
import DocsLayout from "../../layouts/DocsLayout.astro";
const MARKUP_PERCENTAGE = 25;
const TOKENS_PER_CREDIT = 1_000;

const PLAN_LIMITS = {
  free: { credits: 100, overage_per_credit_cents: 0 },
  starter: { credits: 2_000, overage_per_credit_cents: 1 },
  pro: { credits: 8_000, overage_per_credit_cents: 0.8 },
  enterprise: { credits: -1, overage_per_credit_cents: 0 },
} as const;

const SUPPORTED_MODELS = [
  { id: "claude-opus-4-6", name: "Claude Opus 4.6", provider: "anthropic", input_cost_per_million: 5_000, output_cost_per_million: 25_000, max_tokens: 8192 },
  { id: "gpt-5.2", name: "GPT-5.2", provider: "openai", input_cost_per_million: 1_750, output_cost_per_million: 14_000, max_tokens: 128000 },
  { id: "gpt-5.2-chat-latest", name: "GPT-5.2 Instant", provider: "openai", input_cost_per_million: 1_750, output_cost_per_million: 14_000, max_tokens: 128000 },
  { id: "gpt-5.3-codex", name: "GPT-5.3-Codex", provider: "openai", input_cost_per_million: 1_750, output_cost_per_million: 14_000, max_tokens: 128000 },
  { id: "claude-sonnet-4-20250514", name: "Claude Sonnet 4", provider: "anthropic", input_cost_per_million: 3_000, output_cost_per_million: 15_000, max_tokens: 8192 },
  { id: "claude-3-5-haiku-20241022", name: "Claude Haiku 3.5", provider: "anthropic", input_cost_per_million: 250, output_cost_per_million: 1_250, max_tokens: 8192 },
  { id: "gpt-4o", name: "GPT-4o", provider: "openai", input_cost_per_million: 2_500, output_cost_per_million: 10_000, max_tokens: 16384 },
  { id: "gpt-4o-mini", name: "GPT-4o Mini", provider: "openai", input_cost_per_million: 150, output_cost_per_million: 600, max_tokens: 16384 },
  { id: "gemini-2.5-pro", name: "Gemini 2.5 Pro", provider: "google", input_cost_per_million: 1_250, output_cost_per_million: 10_000, max_tokens: 65536 },
  { id: "gemini-2.5-flash", name: "Gemini 2.5 Flash", provider: "google", input_cost_per_million: 300, output_cost_per_million: 2_500, max_tokens: 65536 },
  { id: "glm-5", name: "GLM-5", provider: "zai", input_cost_per_million: 20, output_cost_per_million: 110, max_tokens: 128000 },
  { id: "glm-4.6", name: "GLM-4.6", provider: "zai", input_cost_per_million: 80, output_cost_per_million: 200, max_tokens: 128000 },
  { id: "mistral-large-latest", name: "Mistral Large Latest", provider: "mistral", input_cost_per_million: 2_000, output_cost_per_million: 6_000, max_tokens: 32000 },
  { id: "mistral-small-latest", name: "Mistral Small Latest", provider: "mistral", input_cost_per_million: 200, output_cost_per_million: 600, max_tokens: 32000 },
] as const;
const providerLabel: Record<string, string> = {
  anthropic: "Anthropic",
  openai: "OpenAI",
  google: "Google",
  zai: "z.ai",
  mistral: "Mistral",
};

const models = [...SUPPORTED_MODELS]
  .map((model) => ({
    ...model,
    input_cost_with_markup: Math.ceil(
      model.input_cost_per_million * (1 + MARKUP_PERCENTAGE / 100),
    ),
    output_cost_with_markup: Math.ceil(
      model.output_cost_per_million * (1 + MARKUP_PERCENTAGE / 100),
    ),
  }))
  .sort((a, b) => a.provider.localeCompare(b.provider) || a.name.localeCompare(b.name));

function formatUsdPerMillion(cents: number): string {
  return `$${(cents / 100).toFixed(2)} / 1M`;
}

function formatCredits(value: number): string {
  if (value < 0) return "Custom";
  return value.toLocaleString("en-US");
}

function formatCents(value: number): string {
  if (value <= 0) return "N/A";
  return `€${(value / 100).toFixed(3)}`;
}
---

<DocsLayout title="Models & Pricing" breadcrumb={[{ label: "Docs", href: "/docs" }, { label: "Models & Pricing" }]}>
  <h1 id="overview">Models & Pricing</h1>
  <p>stepIQ is model-agnostic. Each step can use a different model, and runtime prices are calculated from the same constants used by the API and worker.</p>

  <h2 id="available-models">Available models</h2>

  <div class="docs-card-grid">
    {models.map((model) => (
      <div class="model-card">
        <span class="model-provider">{providerLabel[model.provider] || model.provider}</span>
        <h3>{model.name}</h3>
        <p style="color:var(--text-secondary);font-size:0.875rem;margin:0;">
          <code>{model.id}</code> • Max tokens: {model.max_tokens.toLocaleString("en-US")}
        </p>
        <span class="model-pricing">
          {formatUsdPerMillion(model.input_cost_with_markup)} in • {formatUsdPerMillion(model.output_cost_with_markup)} out
        </span>
      </div>
    ))}
  </div>
  <p style="margin-top:0.75rem;">These are the same marked-up prices returned by <code>GET /api/models</code> (base provider price + {MARKUP_PERCENTAGE}% markup).</p>

  <h2 id="credit-system">Credit system</h2>
  <p>Credits are tracked per account plan. Token-to-credit conversion is implemented as <code>1 credit = {TOKENS_PER_CREDIT.toLocaleString("en-US")} tokens</code> for legacy/BYOK-style deduction paths.</p>

  <table class="docs-table">
    <thead><tr><th>Plan</th><th>Included credits</th><th>Overage rate per credit</th></tr></thead>
    <tbody>
      <tr><td>Free</td><td>{formatCredits(PLAN_LIMITS.free.credits)}</td><td>{formatCents(PLAN_LIMITS.free.overage_per_credit_cents)}</td></tr>
      <tr><td>Starter</td><td>{formatCredits(PLAN_LIMITS.starter.credits)}</td><td>{formatCents(PLAN_LIMITS.starter.overage_per_credit_cents)}</td></tr>
      <tr><td>Pro</td><td>{formatCredits(PLAN_LIMITS.pro.credits)}</td><td>{formatCents(PLAN_LIMITS.pro.overage_per_credit_cents)}</td></tr>
      <tr><td>Enterprise</td><td>{formatCredits(PLAN_LIMITS.enterprise.credits)}</td><td>{formatCents(PLAN_LIMITS.enterprise.overage_per_credit_cents)}</td></tr>
    </tbody>
  </table>

  <h2 id="cost-estimation">Cost estimation</h2>
  <p>Current implementation computes cost from measured token usage at execution time. There is no dedicated pre-run estimation endpoint yet.</p>
  <p>Per step:</p>
  <pre class="code-body"><code>base_cost_cents =
  (input_tokens / 1_000_000) * input_cost_per_million +
  (output_tokens / 1_000_000) * output_cost_per_million

step_cost_cents = ceil(base_cost_cents * (1 + {MARKUP_PERCENTAGE} / 100))</code></pre>
  <p>Run totals are the sum of step costs. Credits are then deducted by funding mode:</p>
  <ul>
    <li><code>app_credits</code> (Starter/Pro with platform keys): <code>ceil(total_cost_cents / overage_per_credit_cents)</code></li>
    <li><code>legacy</code> (e.g. free): <code>ceil(total_tokens / {TOKENS_PER_CREDIT.toLocaleString("en-US")})</code></li>
    <li><code>byok_required</code>: <code>0</code> credits deducted by platform</li>
  </ul>

  <div class="code-card">
    <div class="code-header">
      <div class="code-dots"><span class="code-dot red"></span><span class="code-dot yellow"></span><span class="code-dot green"></span></div>
      <span class="code-filename">run-cost-example.txt</span>
    </div>
    <pre class="code-body"><code>Run: weekly-blog-generator
Funding mode: app_credits (starter)

Total tokens: 42,600
Total cost: 62 cents
Credits deducted: ceil(62 / 1) = 62 credits

If the same run used legacy mode:
credits deducted: ceil(42,600 / {TOKENS_PER_CREDIT.toLocaleString("en-US")}) = 43 credits</code></pre>
  </div>
</DocsLayout>
