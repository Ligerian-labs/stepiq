---
import Layout from "../../layouts/Layout.astro";

const APP_URL = import.meta.env.PUBLIC_APP_URL || "http://localhost:5173";

const benefits = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: "SSO, SAML et conformité SOC 2",
    desc: "Sécurité de niveau entreprise intégrée dès le premier jour",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    title: "Infrastructure dédiée et SLA",
    desc: "Workers isolés avec disponibilité garantie pour vos pipelines",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: "Onboarding et support prioritaire",
    desc: "Ingénieur solutions dédié et temps de réponse < 24h",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
    title: "Endpoints de modèles personnalisés",
    desc: "Apportez vos propres modèles et connectez-vous à vos systèmes internes",
  },
];

const teamSizes = ["1-10", "11-50", "51-200", "201-1000", "1000+"];
---

<Layout
  title="stepIQ — Contacter l'équipe commerciale"
  description="Discutez avec l'équipe stepIQ des plans entreprise, des exigences de sécurité et de l'infrastructure dédiée pour vos workflows IA."
  path="/fr/contact"
  lang="fr"
>
  <main class="landing">
    <header class="header">
      <div class="brand">
        <div class="logo-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8" rx="2"/><rect x="13" y="3" width="8" height="8" rx="2"/><rect x="3" y="13" width="8" height="8" rx="2"/><rect x="13" y="13" width="8" height="8" rx="2"/></svg>
        </div>
        <a href="/fr"><span>stepIQ</span></a>
      </div>
      <nav class="nav-links">
        <a href="/fr#features">Fonctionnalités</a>
        <a href="/fr#pricing">Tarifs</a>
        <a href="/fr/docs">Docs</a>
      </nav>
      <div class="actions">
        <a href="/contact" class="ghost-link" style="padding:6px 10px;font-size:12px;letter-spacing:1px;font-weight:600;">EN</a>
        <a href={`${APP_URL}/login`} class="ghost-link">Connexion</a>
        <a href={`${APP_URL}/register`} class="solid-link">Commencer</a>
      </div>
    </header>

    <section class="contact-page">
      <div class="contact-left">
        <div class="enterprise-badge"><span class="dot cyan"></span> Enterprise</div>
        <div class="contact-hero-text">
          <h1>Faisons évoluer votre<br />infrastructure IA</h1>
          <p class="contact-sub">Obtenez un plan personnalisé adapté à la charge de travail de votre équipe, vos exigences de conformité et votre trajectoire de croissance. Nos ingénieurs solutions concevront la bonne architecture pour vous.</p>
        </div>
        <div class="benefits-list">
          {benefits.map((b) => (
            <div class="benefit-item">
              <div class="benefit-icon" set:html={b.icon} />
              <div class="benefit-text">
                <strong>{b.title}</strong>
                <p>{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="contact-right">
        <div class="form-card">
          <h2 class="form-title">Parlez à notre équipe</h2>
          <form method="POST" action="/api/contact">
            <div class="form-row">
              <div class="form-field">
                <label for="fname">Prénom</label>
                <input type="text" id="fname" name="firstName" placeholder="Marie" required />
              </div>
              <div class="form-field">
                <label for="lname">Nom</label>
                <input type="text" id="lname" name="lastName" placeholder="Dupont" required />
              </div>
            </div>
            <div class="form-field">
              <label for="email">Email professionnel</label>
              <input type="email" id="email" name="email" placeholder="marie@entreprise.fr" required />
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="company">Entreprise</label>
                <input type="text" id="company" name="company" placeholder="Acme SAS" required />
              </div>
              <div class="form-field">
                <label for="teamSize">Taille de l'équipe</label>
                <select id="teamSize" name="teamSize" required>
                  <option value="" disabled selected>Sélectionner</option>
                  {teamSizes.map((size) => (
                    <option value={size}>{size}</option>
                  ))}
                </select>
              </div>
            </div>
            <div class="form-field">
              <label for="message">Comment pouvons-nous vous aider ?</label>
              <textarea id="message" name="message" rows="4" placeholder="Décrivez votre cas d'utilisation, la taille de votre équipe et vos besoins spécifiques..."></textarea>
            </div>
            <button type="submit" class="solid-link submit-btn">Nous contacter <span class="arrow-icon">→</span></button>
          </form>
          <p class="privacy-note">En soumettant, vous acceptez notre <a href="/fr/privacy">Politique de confidentialité</a>. Nous répondrons sous un jour ouvré.</p>
        </div>
      </div>
    </section>
  </main>
</Layout>
